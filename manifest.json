{
  "manifest_version": 3,
  "name": "CanvasHack",
  "version": "2.0.0",
  "description": "Privacy guard, answer saver, and AI answer engine for Canvas quizzes.",
  "permissions": [
    "storage",
    "contextMenus",
    "scripting",
    "activeTab"
  ],
  "host_permissions": [
    "<all_urls>",
    "file:///*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>", "file:///*"],
      "js": ["content.js"],
      "run_at": "document_start",
      "all_frames": true
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "CanvasHack"
  },
  "web_accessible_resources": [
    {
      "resources": [
        "inject.js",
        "ai-answers.js",
        "quizanswers.js",
        "test-page.html",
        "test-page.js"
      ],
      "matches": ["<all_urls>", "file:///*"]
    }
  ],
  "icons": {
    "128": "icons/icon128.png"
  }
}
